# ═══════════════════════════════════════════════════════
#  Imba Production — Environment Variables
#  Copy to .env and fill in your values.
#  NEVER commit .env to git.
# ═══════════════════════════════════════════════════════

# ── App ─────────────────────────────────────────────────
APP_PORT=9102
APP_DOMAIN=imbaproduction.com
VITE_APP_URL=https://imbaproduction.com

# ── Supabase (self-hosted) ───────────────────────────────
# These are generated by Supabase — use jwt.io to generate
# or run: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-this-min-32-chars
JWT_EXPIRY=3600

# The anon key is a JWT signed with JWT_SECRET, role=anon
SUPABASE_ANON_KEY=your-anon-jwt-here
# The service key is a JWT signed with JWT_SECRET, role=service_role
SUPABASE_SERVICE_KEY=your-service-role-jwt-here

# These are what the frontend uses
VITE_SUPABASE_URL=https://supabase.imbaproduction.com
VITE_SUPABASE_ANON_KEY=your-anon-jwt-here

# Supabase public URL (Kong gateway)
SUPABASE_PUBLIC_URL=https://supabase.imbaproduction.com
SUPABASE_AUTH_EXTERNAL_URL=https://supabase.imbaproduction.com/auth/v1

# ── PostgreSQL ───────────────────────────────────────────
POSTGRES_DB=imba_production
POSTGRES_USER=supabase
POSTGRES_PASSWORD=change-this-strong-password
POSTGRES_PORT=15432

# ── Redis ────────────────────────────────────────────────
REDIS_PASSWORD=change-this-redis-password
REDIS_PORT=16379
REDIS_MAX_MEMORY=256mb

# ── Ports (internal, Traefik handles external) ───────────
POSTGREST_PORT=9103
AUTH_PORT=9104
STORAGE_PORT=9105
KONG_HTTP_PORT=9100
STUDIO_PORT=9101

# ── Domains (for Traefik labels) ─────────────────────────
SUPABASE_DOMAIN=supabase.imbaproduction.com
STUDIO_DOMAIN=studio.imbaproduction.com

# ── Supabase Studio auth (htpasswd format) ───────────────
# Generate: htpasswd -nb admin yourpassword
STUDIO_AUTH_USERS=admin:$$apr1$$yourhash
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=change-this-dashboard-password
STUDIO_DEFAULT_ORGANIZATION=Imba Production
STUDIO_DEFAULT_PROJECT=imba-production

# ── SMTP (for Supabase Auth emails) ─────────────────────
SMTP_HOST=smtp.mailgun.org
SMTP_PORT=587
SMTP_USER=your-mailgun-user
SMTP_PASS=your-mailgun-password
SMTP_ADMIN_EMAIL=admin@imbaproduction.com
SMTP_SENDER_NAME=Imba Production
MAILER_AUTOCONFIRM=false

# ── Auth settings ────────────────────────────────────────
DISABLE_SIGNUP=true
GOTRUE_URI_ALLOW_LIST=https://imbaproduction.com
